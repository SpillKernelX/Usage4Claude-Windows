{
  "name": "usage4claude",
  "version": "1.0.2",
  "description": "Claude usage monitor for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.usage4claude.app",
    "productName": "Usage4Claude",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "SpillKernelX",
      "repo": "Usage4Claude-Windows"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
